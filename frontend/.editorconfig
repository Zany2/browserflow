# EditorConfig 编辑器规范，统一缩进、换行和尾随空格
root = true

# Default rules 默认规则，适用于项目内大部分文件
[*]
charset = utf-8
indent_style = space
indent_size = 2
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 80

# Frontend sources 前端源码，保持和 Prettier 的 2 空格风格一致
[*.{js,jsx,mjs,cjs,vue,html,css,scss,sass,less,styl}]
indent_style = space
indent_size = 2

# Data files 数据文件，统一使用 2 空格缩进
[*.{json,jsonc,yml,yaml}]
indent_style = space
indent_size = 2

# Markdown markdown，保留尾随空格以避免破坏手动换行
[*.md]
trim_trailing_whitespace = false
